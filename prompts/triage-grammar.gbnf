root ::= ignore | remember | whisper | exec | wake

ignore  ::= "{\"decision\":\"ignore\"}"
remember ::= "{\"decision\":\"remember\",\"summary\":" ws str "}"
whisper  ::= "{\"decision\":\"whisper\",\"text\":" ws str "}"
exec     ::= "{\"decision\":\"execute_simple\",\"action\":" ws str "}"
wake     ::= "{\"decision\":\"wake_orchestrator\",\"reason\":" ws str "}"

str ::= "\"" ([^"\\] | "\\" ["\\/bfnrt])* "\""
ws  ::= " "?
